RewriteEngine On
DirectoryIndex index.php

# 0. Modern Security: Block sensitive files (e.g., .env)
RedirectMatch 404 /\.git
RedirectMatch 404 /\.env
RedirectMatch 404 /composer\.(json|lock)
RedirectMatch 404 /package(-lock)?\.json

# 1. SSL Redirect (Exclude localhost)
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1|192\.168\.)
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. Prevent directory indexing gracefully
<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

# 3. Explicit Backend & Component Routes
# These provide clean URLs for core functionality

# Game Room: /room/CODE -> index.php (handled by MVC controller)
RewriteRule ^room/([A-Za-z0-9]+)/?$ index.php [QSA,L]

# Admin Interface: Clean Routes
RewriteRule ^admin/?$ admin/index.php [L]
RewriteRule ^admin/login/?$ admin/login.php [L]
RewriteRule ^admin/rooms/?$ admin/rooms.php [L]
RewriteRule ^admin/words/?$ admin/words.php [L]
RewriteRule ^admin/avatars/?$ admin/avatars.php [L]
RewriteRule ^admin/music/?$ admin/music.php [L]

# 4. Fallback Routing (Enables SPA-like architecture)
# If the request is for a real file/directory, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise, route through index.php
RewriteRule . index.php [L,QSA]
